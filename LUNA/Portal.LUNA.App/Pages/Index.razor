@page "/"
@inject ApiClient ApiClient
@inject NavigationManager NavManager

<PageTitle>LUNA Portal</PageTitle>

@if (!isLoggedIn)
{
    <div class="jumbotron p-5 bg-light rounded">
        <h1>🌙 LUNA Portal</h1>
        <p class="lead">Local Universal Neural Assistant — Manage your MCP servers and API keys.</p>
        <a class="btn btn-primary me-2" href="/login">Login</a>
        <a class="btn btn-secondary" href="/register">Register</a>
    </div>
}
else
{
    <h2>Available MCP Servers</h2>

    @if (loading)
    {
        <div class="spinner-border" role="status"></div>
    }
    else if (!servers.Any())
    {
        <div class="alert alert-info">No MCP servers are currently available.</div>
    }
    else
    {
        @foreach (var server in servers)
        {
            var userKey = userKeys.FirstOrDefault(k => k.McpServerId == server.Id && k.RevokedAt == null);
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@server.Name</h5>
                    @if (userKey != null)
                    {
                        <span class="badge bg-success">Key Active</span>
                    }
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(server.Description))
                    {
                        <p>@server.Description</p>
                    }
                    @if (userKey == null)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="() => GenerateKey(server.Id)">
                            Generate API Key
                        </button>
                    }
                    else
                    {
                        <div class="mb-2">
                            <strong>API Key:</strong>
                            <code class="ms-2">@userKey.ApiKey</code>
                            <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="() => CopyToClipboard(userKey.ApiKey)">
                                <i class="bi bi-clipboard"></i> Copy
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(rootDomain))
                        {
                            var mcpUrl = $"http://{rootDomain}/mcp/{server.Name}";
                            <div class="mb-2">
                                <strong>MCP URL:</strong>
                                <code class="ms-2">@mcpUrl</code>
                                <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="() => CopyToClipboard(mcpUrl)">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        }
                        <div class="mt-3">
                            <h6>Settings</h6>
                            @foreach (var setting in userKey.Settings)
                            {
                                <div class="d-flex gap-2 mb-2 align-items-center">
                                    <input class="form-control form-control-sm" style="max-width:150px" value="@setting.Key" readonly />
                                    <input class="form-control form-control-sm" style="max-width:250px" type="text"
                                           @bind="settingValues[setting.Id]" />
                                    <button class="btn btn-sm btn-success" @onclick="() => SaveSetting(userKey.Id, setting.Key, settingValues[setting.Id])">Save</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteSetting(setting.Id)">Delete</button>
                                </div>
                            }
                            <div class="d-flex gap-2 mt-2">
                                <input class="form-control form-control-sm" style="max-width:150px" placeholder="Key" @bind="newSettingKey" />
                                <input class="form-control form-control-sm" style="max-width:250px" placeholder="Value" @bind="newSettingValue" />
                                <button class="btn btn-sm btn-primary" @onclick="() => AddSetting(userKey.Id)">Add</button>
                            </div>
                        </div>
                        <button class="btn btn-outline-danger btn-sm mt-3" @onclick="() => RevokeKey(userKey.Id)">Revoke Key</button>
                    }
                </div>
            </div>
        }
    }
}

@code {
    private bool isLoggedIn;
    private bool loading = true;
    private List<AvailableMcpServerDto> servers = new();
    private List<UserApiKeyDto> userKeys = new();
    private Dictionary<string, string> settingValues = new();
    private string? rootDomain;
    private string newSettingKey = "";
    private string newSettingValue = "";

    protected override async Task OnInitializedAsync()
    {
        isLoggedIn = await ApiClient.IsLoggedInAsync();
        if (!isLoggedIn) { loading = false; return; }
        await LoadData();
        loading = false;
    }

    private async Task LoadData()
    {
        servers = await ApiClient.GetEnabledMcpServersAsync();
        userKeys = await ApiClient.GetMyApiKeysAsync();
        rootDomain = await ApiClient.GetRootDomainAsync();
        settingValues = userKeys.SelectMany(k => k.Settings)
            .ToDictionary(s => s.Id, s => s.Value);
    }

    private async Task GenerateKey(string mcpServerId)
    {
        await ApiClient.GenerateApiKeyAsync(mcpServerId);
        await LoadData();
    }

    private async Task RevokeKey(string id)
    {
        await ApiClient.RevokeApiKeyAsync(id);
        await LoadData();
    }

    private async Task SaveSetting(string apiKeyId, string key, string value)
    {
        await ApiClient.UpsertSettingAsync(apiKeyId, key, value);
        await LoadData();
    }

    private async Task DeleteSetting(string settingId)
    {
        await ApiClient.DeleteSettingAsync(settingId);
        await LoadData();
    }

    private async Task AddSetting(string apiKeyId)
    {
        if (string.IsNullOrWhiteSpace(newSettingKey)) return;
        await ApiClient.UpsertSettingAsync(apiKeyId, newSettingKey, newSettingValue);
        newSettingKey = "";
        newSettingValue = "";
        await LoadData();
    }

    private void CopyToClipboard(string text)
    {
        // Clipboard copy via JS interop would be ideal but not added to keep it simple
    }
}
