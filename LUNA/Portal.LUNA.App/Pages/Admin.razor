@attribute [Authorize(Roles = "Administrator")]
@page "/admin"
@inject Portal.LUNA.App.Services.API API
@inject NavigationManager Navigation
@inject IModalService _modalService
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Admin - LUNA</PageTitle>

<div class="row mt-3">
    <div class="col-md-12">
        <h3>System Settings</h3>
        <hr />
    </div>
</div>

@if (SystemSettings != null)
{
    <div class="row">
        <div class="col-md-5">
            <div class="row mt-1">
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text">Portal Root URL</span>
                        <input type="text" class="form-control" @bind="SystemSettings.PortalRootUrl" placeholder="https://yourdomain.com" />
                    </div>
                    <small class="text-muted">Used to build MCP server addresses shown to users.</small>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text">Email API Key</span>
                        <input type="text" class="form-control" @bind="SystemSettings.EmailApiKey" />
                    </div>
                </div>
            </div>
            <div class="row mt-1">
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text">System Email Address</span>
                        <input type="text" class="form-control" @bind="SystemSettings.SystemEmailAddress" />
                    </div>
                </div>
            </div>
            <div class="row mt-1">
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text">Email Domain Restrictions</span>
                        <input type="text" class="form-control" @bind="SystemSettings.EmailDomainRestriction" />
                    </div>
                </div>
            </div>
            <div class="row mt-1">
                <div class="col-md-12">
                    <div class="input-group w-100">
                        <span class="input-group-text">Registration Enabled</span>
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="checkbox" @bind="SystemSettings.RegistrationEnabled" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-12">
                    <button class="btn btn-primary" @onclick="SaveSettings">Save Settings</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="row mt-5">
    <div class="col-md-12">
        <h3>Users</h3>
        <hr />
    </div>
</div>
<div class="row">
    <div class="col-md-6 offset-md-6">
        <form class="input-group float-end" @onsubmit="(() => SearchUsers(0, false))" autocomplete="off">
            <input type="text" class="form-control" @bind="Search.FilterText" autocomplete="off" />
            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search me-2"></i>Search</button>
        </form>
    </div>
</div>
<div class="row mt-1">
    <div class="col-md-12">
        <span class="btn btn-link btn-sm float-end pointer" @onclick="(() => SearchUsers(0, true))">Reset</span>
    </div>
</div>
<div class="row">
    <div class="col-md-12 table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Users)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       checked="@user.IsAdministrator"
                                       @onchange="() => ToggleAdmin(user)"
                                       disabled="@user.IsSelf" />
                                <label class="form-check-label">Administrator</label>
                            </div>
                        </td>
                        <td>
                            @if (!user.IsSelf)
                            {
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteUser(user)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <nav>
            <ul class="pagination float-end">
                @if (Search.Page > 0)
                {
                    <li class="page-item pointer"><div class="page-link" @onclick="(() => SearchUsers(Search.Page - 1, false))">Previous</div></li>
                }
                <li class="page-item"><div class="page-link">Page @(TotalFound == 0 ? 0 : Search.Page + 1) of @(Math.Ceiling((double)TotalFound / Search.PageSize))</div></li>
                @if ((Search.Page + 1) < Math.Ceiling((double)TotalFound / Search.PageSize))
                {
                    <li class="page-item pointer"><div class="page-link" @onclick="(() => SearchUsers(Search.Page + 1, false))">Next</div></li>
                }
            </ul>
        </nav>
    </div>
</div>

@code {
    private Portal.LUNA.Dto.SystemSettings? SystemSettings { get; set; }
    private Search Search { get; set; } = new Search { SortBy = nameof(User.Email) };
    private List<User> Users { get; set; } = new();
    private int TotalFound { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SystemSettings = await API.GetAsync<Portal.LUNA.Dto.SystemSettings>("api/v1/settings");
        await SearchUsers(0, true);
    }

    private async Task SaveSettings()
    {
        if (SystemSettings != null)
            await API.PutAsync("api/v1/settings", SystemSettings);
    }

    private async Task SearchUsers(int page, bool reset)
    {
        if (reset)
        {
            Search = new Search { SortBy = nameof(User.Email) };
            page = 0;
        }
        Search.Page = page;
        var result = await API.PostAsync<SearchResponse<User>>("api/v1/users", Search);
        if (result != null)
        {
            Users = result.Results;
            TotalFound = result.Total;
        }
    }

    private async Task ToggleAdmin(User user) =>
        await API.GetAsync($"api/v1/user/{user.Id}/role/administrator");

    private async Task DeleteUser(User user)
    {
        var modal = _modalService.Show<ConfirmDialog>("Confirm delete user?");
        var result = await modal.Result;
        if (!result.Cancelled)
        {
            if (await API.DeleteAsync($"api/v1/user/{user.Id}"))
                Users.Remove(user);
        }
    }
}
