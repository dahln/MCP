@inherits LayoutComponentBase
@inject Portal.LUNA.App.Services.ApiClient ApiClient
@inject NavigationManager NavManager
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage

<div class="page">
    <header class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🌙 LUNA Portal</a>
            <div class="d-flex gap-2">
                @if (isLoggedIn)
                {
                    <span class="navbar-text text-light me-2">@email</span>
                    @if (isAdmin)
                    {
                        <a class="btn btn-outline-warning btn-sm" href="/admin">Admin</a>
                    }
                    <button class="btn btn-outline-light btn-sm" @onclick="Logout">Logout</button>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" href="/login">Login</a>
                    <a class="btn btn-outline-light btn-sm" href="/register">Register</a>
                }
            </div>
        </div>
    </header>

    <main class="container mt-4">
        @Body
    </main>
</div>

@code {
    private bool isLoggedIn;
    private bool isAdmin;
    private string? email;

    protected override async Task OnInitializedAsync()
    {
        isLoggedIn = await ApiClient.IsLoggedInAsync();
        if (isLoggedIn)
        {
            isAdmin = await ApiClient.IsAdminAsync();
            email = await ApiClient.GetEmailAsync();
        }
    }

    private async Task Logout()
    {
        await ApiClient.LogoutAsync();
        NavManager.NavigateTo("/login", forceLoad: true);
    }
}
